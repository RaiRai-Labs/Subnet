# --- App ---
# Quote any value containing spaces: the PM2 start scripts do `set -a; source .env`,
# and an unquoted spaced value (e.g. APP_NAME=RaiRai Subnet ...) makes the shell try
# to run the extra words as a command and aborts the launch.
APP_NAME="RaiRai Subnet Validator API"
DEBUG=false

# --- Database (async driver required) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# URL-encode special characters in the password (e.g. @ -> %40, $ -> %24).
# Note: run.sh starts a Dockerized Postgres mapped to host port 5433.
DATABASE_URL=postgresql+asyncpg://rairai:rairai@localhost:5433/rairai_subnet

# --- CORS (comma-separated origins, or *) ---
CORS_ORIGINS=*

# --- Neuron launch (read by ecosystem.config.js, start_*.sh, preflight.py) ---
# NETUID=1
# SUBTENSOR_NETWORK=finney
# WALLET_NAME=validator
# WALLET_HOTKEY=default
# Miner only — the chain rejects 127.0.0.1, so advertise your public VPS IP and
# open the port in the firewall (setup.sh can do it: RAIRAI_OPEN_FIREWALL=1).
# AXON_PORT=8091
# AXON_EXTERNAL_IP=
# Auto-updater target (rairai-updater app): set to rairai-miner on a miner box.
# UPDATER_PM2_NAME=rairai-validator

# --- Satellite data (Sentinel Hub) ---
# OAuth2 client credentials (a CLIENT ID + CLIENT SECRET from an OAuth client,
# NOT a user id / api key). When both are set, the feature builder upgrades from
# the deterministic offline stub to live Sentinel-2 NDVI/EVI/NDWI.
#
# Deployment selects the endpoints:
#   cdse       -> Copernicus Data Space (free); create the OAuth client at
#                 https://shapps.dataspace.copernicus.eu/dashboard/
#   commercial -> sentinel-hub.com (trial/paid); client at
#                 https://apps.sentinel-hub.com/dashboard/
# SH_DEPLOYMENT=cdse
# SH_CLIENT_ID=
# SH_CLIENT_SECRET=

# --- Subnet ↔ Backend bridge (REQUIRED in production) ---
# URL of the RaiRai farmer backend. The validator reads challenge-pool and
# satellite-history from here; the backend posts ground-truth here after a
# farmer submits their harvest. Without this the live scoring pipeline is broken.
BACKEND_URL=https://farmer-backend.com

# --- Observability (neurons; read from the environment, loaded by start scripts) ---
# Log verbosity: info | debug | trace
# RAIRAI_LOG_LEVEL=info
# Webhook for start/crash alerts (Discord or Slack incoming webhook URL).
# RAIRAI_ALERT_WEBHOOK=
# Path to a JSON heartbeat/status file for external monitoring (metrics).
# RAIRAI_HEARTBEAT_FILE=/var/run/rairai/validator.json
